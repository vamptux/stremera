{
  "name": "stremera",
  "private": true,
  "version": "0.4.0-beta.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "tauri:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/clean-tauri.ps1",
    "tauri:build": "powershell -ExecutionPolicy Bypass -File ./scripts/build-tauri.ps1",
    "tauri:build:unsigned": "powershell -ExecutionPolicy Bypass -File ./scripts/build-tauri.ps1 -Unsigned",
    "tauri:build:clean": "bun run tauri:clean && bun run tauri:build",
    "lint": "bun run lint:oxlint",
    "lint:oxlint": "oxlint src --deny-warnings --react-plugin -D exhaustive-deps",
    "release:version:check": "bun ./scripts/release-version.mjs check",
    "release:version:set": "bun ./scripts/release-version.mjs set",
    "format": "biome format --write src public index.html package.json components.json postcss.config.js tailwind.config.js tsconfig.json tsconfig.node.json vite.config.ts",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "~2.5.0",
    "@tauri-apps/plugin-store": "^2.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tauri-plugin-libmpv-api": "^0.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "oxlint": "^1.58.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.8.3",
    "vite": "^8.0.3"
  }
}
