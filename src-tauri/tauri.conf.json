{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stremera",
  "version": "0.3.0",
  "identifier": "com.vamptux.streamy",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stremera",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob: asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' https: ws: wss:; media-src 'self' https: blob: data: asset: https://asset.localhost; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com;"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "lib/**/*"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwODY1NzQ5M0IxMTkwNDYKUldSR2tCRTdTVmVHUUZrQXk1NTlDekFFNGdNL0lTelRRcnNVcWhySlJjdFRDa3ZUQktod1IxTkUK",
      "endpoints": [
        "https://github.com/vamptux/stremera/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
