{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "single",
      "bracketSpacing": true,
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "html": {
    "formatter": {
      "enabled": true
    }
  }
}
